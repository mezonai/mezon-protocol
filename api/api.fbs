  title:string;
  description:string;
  end_time_seconds:uint;
  location:string;
  status:int;
  creator_id:long;
  create_time_seconds:uint;
  update_time_seconds:uint;
  type:int;
  attachments:[ubyte];
  preview_imgs:[ubyte];
}

