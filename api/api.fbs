namespace mezon.api;

enum State : int {
  FRIEND = 0,
  INVITE_SENT = 1,
  INVITE_RECEIVED = 2,
  BLOCKED = 3,
}

enum StoreProvider : int {
  APPLE_APP_STORE = 0,
  GOOGLE_PLAY_STORE = 1,
  HUAWEI_APP_GALLERY = 2,
  FACEBOOK_INSTANT_STORE = 3,
}

enum StoreEnvironment : int {
  UNKNOWN = 0,
  SANDBOX = 1,
  PRODUCTION = 2,
}

enum Operator : int {
  NO_OVERRIDE = 0,
  BEST = 1,
  SET = 2,
  INCREMENT = 3,
  DECREMENT = 4,
}

enum PollType : int {
  SINGLE = 0,
  MULTIPLE = 1,
}

